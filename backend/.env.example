OPENAI_API_KEY=sk-...
QDRANT_API_KEY=...
QDRANT_HOST=https://your-cluster.qdrant.io
OPENAI_WORKER_MODEL=gpt-4.1-mini
OPENAI_STRATEGIST_MODEL=gpt-4.1
LLM_MIN_INTERVAL_SECONDS=2.0
TASK_SLEEP_SECONDS=2.0

# Comma-separated allowed CORS origins (production: set to your actual frontend URL)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
